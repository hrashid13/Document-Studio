{
  "name": "interactive-article-studio",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop studio for building Pudding-style interactive articles from an essay + media, exported as a self-contained static web bundle.",
  "author": "Hesham Rashid",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k -s first \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on tcp:127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "build:studio": "vite build",
    "build:viewer": "vite build --config vite.viewer.config.ts",
    "build": "npm run build:studio && npm run build:viewer",
    "start": "electron .",
    "typecheck": "tsc --noEmit",
    "dist": "npm run build && electron-builder --win"
  },
  "build": {
    "appId": "com.heshamrashid.interactive-article-studio",
    "productName": "Interactive Article Studio",
    "directories": {
      "buildResources": "installer",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "!node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "viewer-dist",
        "to": "viewer-dist"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "installer/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "framer-motion": "^12.42.2",
    "mammoth": "^1.12.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "wait-on": "^9.0.10"
  }
}
